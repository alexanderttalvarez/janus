{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "trello": {
      "type": "local",
      "command": ["npx", "-y", "trello-mcp-server"],
      "environment": {
        "TRELLO_API_KEY": "{env:TRELLO_API_KEY}",
        "TRELLO_API_TOKEN": "{env:TRELLO_API_TOKEN}"
      },
      "enabled": true
    },
    "godot": {
      "type": "local",
      "command": ["npx", "-y", "@coding-solo/godot-mcp"],
      "environment": {
        "GODOT_PATH": "/usr/local/bin/godot"
      },
      "enabled": true
    }
  }
}
